# Bubu Lagos web — points at the Bubu backend (port 5050 by default).
# The Bubu backend shares the WodiFair Supabase project (the `bubu` schema)
# and the shared Cloudinary account, but it is a separate Express service
# that owns the e-commerce business logic, admin UI, and storefront APIs.
VITE_API_URL=http://localhost:5050/api
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Public site URL (used in absolute OG / canonical links)
VITE_PUBLIC_SITE_URL=http://localhost:5173

# Error monitoring — Sentry (optional; the logger no-ops in prod if unset)
VITE_SENTRY_DSN=

# Google Analytics 4 (optional)
VITE_GA_ID=
