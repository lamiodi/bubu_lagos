# Root .gitignore for Bubu Lagos monorepo

# Environment variables - NEVER commit these
.env
.env.local
.env.*.local
.env.test
.env.production
.env.staging

# Dependencies
node_modules/

# Build outputs
dist/
build/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
.cache/
