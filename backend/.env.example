# =============================================================
# Bubu Lagos Backend — environment variables
# Copy this file to `.env` for local dev. Set these on Render for prod.
# In production the server REFUSES TO START if any of these are missing
# or still set to a placeholder.
# =============================================================

# ---- Server ----
PORT=5000
NODE_ENV=production

# ---- Database (Supabase Postgres) ----
# Example: postgresql://postgres.PROJECT_REF:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/bubu_lagos

# Pool tuning (optional)
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONN_TIMEOUT_MS=5000

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ---- CORS ----
# Comma-separated list of allowed origins. Use your Vercel frontend URL.
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:3000

# ---- Payment gateway (Paystack) ----
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# ---- Email (Resend) ----
RESEND_API_KEY=re_your_resend_api_key
ADMIN_EMAIL=admin@bubulagos.com
FROM_EMAIL=noreply@bubulagos.com
STORE_NAME=Bubu Lagos

# Abort any Resend call that takes longer than this (ms).
# Prevents a slow email provider from holding open customer requests.
EMAIL_TIMEOUT_MS=5000

# ---- Cloudinary (image uploads) ----
# Shared with the Wodifair backend — same account, different folder.
# Folder is set in src/config/cloudinary.js → "bubu"
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Local disk uploads (legacy) ----
# Render mounts the disk at /data/uploads. Locally you can omit this.
UPLOADS_PATH=./uploads

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Admin login lockout (optional overrides) ----
# After N wrong passwords the account is locked for M minutes.
# Defaults: 5 attempts, 15 minutes.
# ADMIN_MAX_FAILED_LOGINS=5
# ADMIN_LOCKOUT_MINUTES=15
